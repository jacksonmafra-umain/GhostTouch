<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Biometric permission for defense demo -->
    <uses-permission android:name="android.permission.USE_BIOMETRIC" />

    <application
        android:name=".DefenderApp"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@android:style/Theme.Material.NoActionBar">

        <!-- Main entry point -->
        <activity
            android:name=".ui.main.MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Login screen (sensitive — targeted by attacker) -->
        <activity android:name=".ui.login.LoginActivity" />

        <!-- Payment screen (sensitive — targeted by attacker) -->
        <activity android:name=".ui.payment.PaymentActivity" />

        <!-- Dashboard (post-login) -->
        <activity android:name=".ui.dashboard.DashboardActivity" />

        <!-- Settings (defense toggles) -->
        <activity android:name=".ui.settings.SettingsActivity" />
    </application>
</manifest>
